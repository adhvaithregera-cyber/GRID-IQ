rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // users/{uid} — stores isPro and isOwner flags
    match /users/{userId} {
      // A user can read only their own document
      allow read: if request.auth != null && request.auth.uid == userId;

      // Users can update only non-sensitive fields (email, displayName, lastSeen).
      // isPro and isOwner can NEVER be written from the client — set them manually
      // via the Firebase console or Admin SDK only.
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && !('isPro'    in request.resource.data)
                   && !('isOwner'  in request.resource.data);
    }

    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
