rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // users/{uid} — stores isPro and isOwner flags
    match /users/{userId} {
      // A user can read only their own document
      allow read: if request.auth != null && request.auth.uid == userId;

      // Writes are allowed ONLY for the owner account setting their own flags.
      // All other writes (e.g. payment confirmations) must go through
      // a Firebase Admin SDK / Cloud Function — never from the client.
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.auth.token.email in [
                       'adhvaith.regera@gmail.com'
                     ]
                   // Only allow setting isPro/isOwner to true — never false
                   && request.resource.data.isPro == true
                   && request.resource.data.isOwner == true;
    }

    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
